# LaunchKit Environment Variables
# Copy this file to .env.local and fill in your credentials

# Database - PostgreSQL connection string
# Examples:
#   Local: postgresql://user:password@localhost:5432/launchkit
#   Supabase: postgresql://postgres:[password]@db.[project].supabase.co:5432/postgres
#   Neon: postgresql://[user]:[password]@[host]/[dbname]
DATABASE_URL="postgresql://user:password@localhost:5432/launchkit"

# NextAuth Configuration
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="your-super-secret-key-here" # Generate with: openssl rand -base64 32

# OAuth Providers
# Get these from Google Cloud Console: https://console.cloud.google.com
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# Get these from GitHub Settings > Developer settings > OAuth Apps
GITHUB_CLIENT_ID=""
GITHUB_CLIENT_SECRET=""

# Stripe Configuration
# Get your keys from: https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY="sk_test_..."
STRIPE_PUBLISHABLE_KEY="pk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..." # Get this from: stripe listen --print-secret

# Stripe Price IDs - Create products in Stripe Dashboard
STRIPE_PRO_PRICE_ID="price_..."
STRIPE_ENTERPRISE_PRICE_ID="price_..."

# Email Configuration (Resend)
# Get your API key from: https://resend.com/api-keys
RESEND_API_KEY="re_..."
EMAIL_FROM="noreply@yourdomain.com"

# Optional: For production email server
EMAIL_SERVER_HOST="smtp.resend.com"
EMAIL_SERVER_PORT="465"
EMAIL_SERVER_USER="resend"
EMAIL_SERVER_PASSWORD="" # Use RESEND_API_KEY here
